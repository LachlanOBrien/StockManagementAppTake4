@model IEnumerable<StockManagementApp.Models.ItemLocation>

@{
    ViewData["Title"] = "Item Locations";
}

<h1>Item Locations</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Item Name</th>
            <th>Suplier Name</th>
            <th>Location Address</th>
            <th>Quantity</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Item.ItemDescription)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Supplier.SupplierName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Location.LocationAddress)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Quantity)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ItemLocationID">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.ItemLocationID">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.ItemLocationID">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
